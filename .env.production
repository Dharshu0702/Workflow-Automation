# Production Environment Variables
# Copy this to .env.production for deployment

# Backend (Render)
MONGODB_URI=mongodb+srv://your-username:your-password@cluster.mongodb.net/your-database?retryWrites=true&w=majority
#mongodb://localhost:27017/
mongodb+srv://root:<db_password>@cluster0.flkisy3.mongodb.net/
# Frontend (Vercel)
REACT_APP_API_URL=https://your-backend-name.onrender.com

# JWT Secret (if using authentication)
JWT_SECRET=your-super-secret-jwt-key

# CORS Settings
NODE_ENV=production
